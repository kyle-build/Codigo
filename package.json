{
  "name": "codigo",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "prepare": "husky",
    "release": "standard-version",
    "run:client": "pnpm --filter @codigo/client run dev",
    "run:opensumi-app": "pnpm --filter @codigo/opensumi-app run start",
    "run:server": "pnpm --filter @codigo/server run start:dev",
    "run:materials": "pnpm --filter @codigo/materials run dev",
    "run:release": "pnpm --filter @codigo/release run dev",
    "build:client": "pnpm --filter @codigo/client run build",
    "build:opensumi-app": "pnpm --filter @codigo/opensumi-app run build",
    "build:schema": "pnpm --filter @codigo/schema run build",
    "build:server": "pnpm --filter @codigo/server run build",
    "build:release": "pnpm --filter @codigo/release run build",
    "build:plugin-system": "pnpm --filter @codigo/plugin-system run build",
    "build:materials": "pnpm --filter @codigo/materials run build",
    "build:render": "pnpm --filter @codigo/render run build",
    "build:editor-sandbox": "pnpm --filter @codigo/editor-sandbox run build",
    "start:server": "pnpm --filter @codigo/server run start:prod",
    "start:release": "pnpm --filter @codigo/release run start",
    "build:all": "pnpm run build:schema && pnpm run build:materials && pnpm run build:plugin-system && pnpm run build:opensumi-app && pnpm run build:render && pnpm run build:editor-sandbox && pnpm run build:release && pnpm run build:client && pnpm run build:server",
    "commit": "git-cz"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.1.0",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.2.2",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}

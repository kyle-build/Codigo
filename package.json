{
  "name": "codigo",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "prepare": "husky",
    "release": "standard-version",
    "dev": "turbo run dev start:dev start --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "run:client": "pnpm --filter @codigo/client run dev",
    "run:opensumi-app": "pnpm --filter @codigo/opensumi-app run start",
    "run:server": "pnpm --filter @codigo/server run start:dev",
    "run:release": "pnpm --filter @codigo/release run dev",
    "build:client": "turbo run build --filter=@codigo/client",
    "build:opensumi-app": "turbo run build --filter=@codigo/opensumi-app",
    "build:schema": "turbo run build --filter=@codigo/schema",
    "build:server": "turbo run build --filter=@codigo/server",
    "build:release": "turbo run build --filter=@codigo/release",
    "build:plugin-system": "turbo run build --filter=@codigo/plugin-system",
    "build:materials": "turbo run build --filter=@codigo/materials",
    "build:render": "turbo run build --filter=@codigo/render",
    "build:editor-sandbox": "turbo run build --filter=@codigo/editor-sandbox",
    "start:server": "pnpm --filter @codigo/server run start:prod",
    "start:release": "pnpm --filter @codigo/release run start",
    "build:all": "pnpm run build",
    "commit": "git-cz"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "vscode-languageserver-protocol": "3.16.0",
      "vscode-jsonrpc": "6.0.0",
      "yargs": "13.3.2",
      "@opensumi/di": "1.8.0"
    }
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.1.0",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.2.2",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
